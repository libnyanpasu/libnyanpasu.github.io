{
  "extends": [
    "config:base",
    "default:automergeMinor",
    "default:disableRateLimiting",
    "default:rebaseStalePrs",
    "group:allNonMajor"
  ],
  "packageRules": [
    {
      "groupName": "Astro packages",
      "matchPackagePatterns": ["astro", "@astrojs/"]
    },
    {
      "groupName": "React packages",
      "matchPackagePatterns": ["react", "@types/react"]
    },
    {
      "groupName": "TypeScript",
      "matchPackagePatterns": ["typescript"]
    },
    {
      "groupName": "Lint & Format packages",
      "matchPackagePatterns": ["oxlint", "oxfmt", "commitlint", "husky", "lint-staged"]
    },
    {
      "groupName": "Inlang packages",
      "matchPackagePatterns": ["@inlang/"]
    }
  ]
}
