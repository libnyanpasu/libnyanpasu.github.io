{
  "extends": [
    "config:recommended",
    "default:automergeMinor",
    "default:disableRateLimiting",
    "default:rebaseStalePrs",
    "group:allNonMajor"
  ],
  "packageRules": [
    {
      "groupName": "Astro packages",
      "matchPackageNames": [
        "/astro/",
        "/@astrojs//"
      ]
    },
    {
      "groupName": "React packages",
      "matchPackageNames": [
        "/react/",
        "/@types/react/"
      ]
    },
    {
      "groupName": "TypeScript",
      "matchPackageNames": [
        "/typescript/"
      ]
    },
    {
      "groupName": "Lint & Format packages",
      "matchPackageNames": [
        "/oxlint/",
        "/oxfmt/",
        "/commitlint/",
        "/husky/",
        "/lint-staged/"
      ]
    },
    {
      "groupName": "Inlang packages",
      "matchPackageNames": [
        "/@inlang//"
      ]
    }
  ]
}
